# --- Database ---
# Local development uses a local Prisma Postgres instance.
# Start it with:  npm run db:start   (wraps `prisma dev`)
# Then copy the printed `prisma+postgres://...` URL here.
#
# In production, point this at any Postgres database (e.g. Supabase,
# Neon, Prisma Postgres cloud). A standard `postgresql://user:pass@host:5432/db`
# URL works as well.
# Note: when using a connection pooler (such as the local `prisma dev` endpoint
# or Supabase's pooled port), append `?pgbouncer=true` to avoid prepared
# statement conflicts.
DATABASE_URL="postgresql://postgres:postgres@localhost:51214/lovejoy?sslmode=disable&pgbouncer=true"

# --- Auth ---
# Secret used to sign session cookies. Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"

# --- App URL (password reset links) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Vercel Blob (avatar uploads; optional in local dev) ---
BLOB_READ_WRITE_TOKEN=""

# --- Resend (password reset emails; optional in local dev) ---
RESEND_API_KEY=""
EMAIL_FROM="Lovejoy XC Log <noreply@yourdomain.com>"
