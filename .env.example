# --- Database ---
# Local development uses a local Prisma Postgres instance.
# Start it with:  npm run db:start   (wraps `prisma dev`)
# Then copy the printed `prisma+postgres://...` URL here.
#
# In production, point this at any Postgres database (e.g. Supabase,
# Neon, Prisma Postgres cloud). A standard `postgresql://user:pass@host:5432/db`
# URL works as well.
DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."

# --- Auth ---
# Secret used to sign session cookies. Use a long random string in production.
AUTH_SECRET="change-me-to-a-long-random-string"
